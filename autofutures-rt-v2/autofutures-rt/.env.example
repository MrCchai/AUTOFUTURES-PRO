# .env — ตั้งค่าที่นี่ (อย่า commit!)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Binance API
BINANCE_API_KEY=your_key_here
BINANCE_API_SECRET=your_secret_here
TESTNET=true

# Trading
SYMBOL=BTCUSDT
TIMEFRAME=15m
LEVERAGE=5
STRATEGY=TREND          # TREND | SCALP

# Position Sizing — ใช้ % ของ balance จริง
POSITION_ALLOC_PCT=0.80     # 80% ของ balance (เปลี่ยนได้ 0.0–1.0)
POSITION_MIN_USDT=10        # ขั้นต่ำสุดที่จะเทรด (USDT)
STOP_LOSS_PCT=1.5
TAKE_PROFIT_PCT=3.0
MAX_DAILY_LOSS=50
TRAILING_STOP=true
TRAILING_PCT=0.8

# Strategy Params
EMA_FAST=20
EMA_SLOW=50
MACD_FAST=12
MACD_SLOW=26
MACD_SIG=9
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
BB_PERIOD=20
BB_STD=2.0

# Telegram
TELEGRAM_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080        # WebSocket port
DASHBOARD_PASS=changeme    # ใส่ password ที่ต้องการ
